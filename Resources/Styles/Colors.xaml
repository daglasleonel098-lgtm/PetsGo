<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Backgrounds -->
    <Color x:Key="BackgroundColor">#0F0F0F</Color>
    <Color x:Key="CardColor">#1E1E1E</Color>

    <!-- Primary -->
    <Color x:Key="Primary">#4CAF50</Color>
    <Color x:Key="PrimaryDark">#388E3C</Color>

    <!-- Text -->
    <Color x:Key="TextColor">White</Color>
    <Color x:Key="SecondaryTextColor">#BDBDBD</Color>

    <!-- Inputs -->
    <Color x:Key="InputBackground">#2A2A2A</Color>

    <!-- Borders -->
    <Color x:Key="BorderColor">#333333</Color>

</ResourceDictionary>