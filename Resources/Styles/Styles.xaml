<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- PAGE -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundColor}" />
    </Style>

    <!-- LABEL -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource TextColor}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <!-- TITLE -->
    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="White" />
    </Style>

    <!-- SUBTITLE -->
    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource SecondaryTextColor}" />
    </Style>

    <!-- BUTTON -->
    <Style TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="HeightRequest" Value="55" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="Margin" Value="0,8" />
    </Style>

    <!-- PRIMARY BUTTON -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="HeightRequest" Value="55" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
    </Style>

    <!-- ENTRY -->
    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="PlaceholderColor" Value="#888888" />
        <Setter Property="HeightRequest" Value="55" />
        <Setter Property="Margin" Value="0,6" />
    </Style>

    <!-- PICKER -->
    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource InputBackground}" />
        <Setter Property="TextColor" Value="White" />
        <Setter Property="TitleColor" Value="#888888" />
        <Setter Property="HeightRequest" Value="55" />
    </Style>

    <!-- FRAME CARD -->
    <Style TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource CardColor}" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="BorderColor" Value="{StaticResource BorderColor}" />
    </Style>

</ResourceDictionary>