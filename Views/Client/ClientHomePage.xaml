<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PetsGo.Views.Client.ClientHomePage"
    Title="Cliente"
    BackgroundColor="#0F0F0F">

    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="20">

            <!-- HEADER -->

            <Label
                Text="PetsGo 🐾"
                FontSize="34"
                FontAttributes="Bold"
                TextColor="White" />

            <Label
                Text="¿Qué deseas hacer hoy?"
                FontSize="18"
                TextColor="#BDBDBD" />

            <!-- MAPA -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="📍 Ver Paseadores"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Encuentra paseadores cercanos"
                        TextColor="#BDBDBD" />

                    <Button
                        Text="Abrir"
                        Clicked="OnMapClicked"
                        BackgroundColor="#4CAF50"
                        Margin="0,10,0,0" />

                </VerticalStackLayout>

            </Frame>

            <!-- SOLICITAR -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="🐶 Solicitar Paseo"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Solicita un paseo rápidamente"
                        TextColor="#BDBDBD" />

                    <Button
                        Text="Solicitar"
                        Clicked="OnRequestWalkClicked"
                        BackgroundColor="#4CAF50"
                        Margin="0,10,0,0" />

                </VerticalStackLayout>

            </Frame>

            <!-- SOLICITUDES -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="📋 Mis Solicitudes"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Revisa tus solicitudes"
                        TextColor="#BDBDBD" />

                    <Button
                        Text="Ver"
                        Clicked="OnRequestsClicked"
                        BackgroundColor="#4CAF50"
                        Margin="0,10,0,0" />

                </VerticalStackLayout>

            </Frame>

            <!-- CHAT -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="💬 Chat"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Habla con paseadores"
                        TextColor="#BDBDBD" />

                    <Button
                        Text="Abrir"
                        Clicked="OnChatClicked"
                        BackgroundColor="#4CAF50"
                        Margin="0,10,0,0" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>