<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PetsGo.Views.Walker.WalkerRequestsPage"
    Title="Solicitudes"
    BackgroundColor="#121212">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="15">

            <Label
                Text="Solicitudes Disponibles"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White" />

            <!-- CARD -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#2E7D32"
                CornerRadius="18">

                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="Cliente: María"
                        FontAttributes="Bold"
                        FontSize="18"
                        TextColor="White" />

                    <Label
                        Text="Distancia: 2.1km"
                        TextColor="#BBBBBB" />

                    <Label
                        Text="Horario: 16:00"
                        TextColor="#BBBBBB" />

                    <Grid ColumnDefinitions="*,*">

                        <Button
                            Text="Aceptar"
                            BackgroundColor="#4CAF50"
                            TextColor="White"
                            CornerRadius="14" />

                        <Button
                            Grid.Column="1"
                            Text="Rechazar"
                            BackgroundColor="#B71C1C"
                            TextColor="White"
                            CornerRadius="14"
                            Margin="10,0,0,0" />

                    </Grid>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>