<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="PetsGo.Views.Walker.WalkerHomePage"
    Title="Inicio"
    BackgroundColor="#0F0F0F">

    <ScrollView>

        <VerticalStackLayout
            Padding="25"
            Spacing="20">

            <!-- HEADER -->

            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout>

                    <Label
                        Text="PetsGo 🐾"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        x:Name="WelcomeLabel"
                        TextColor="#BDBDBD"
                        FontSize="18" />

                </VerticalStackLayout>

                <Frame
                    WidthRequest="50"
                    HeightRequest="50"
                    CornerRadius="25"
                    BackgroundColor="#4CAF50"
                    HorizontalOptions="End"
                    VerticalOptions="Center">

                    <Label
                        Text="👤"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        FontSize="24" />

                </Frame>

            </Grid>

            <!-- RECORDATORIO -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="📅 Recordatorio"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Recuerda actualizar tus horarios disponibles."
                        TextColor="#BDBDBD" />

                </VerticalStackLayout>

            </Frame>

            <!-- SOLICITUDES -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="🐶 Solicitudes"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Revisa las solicitudes disponibles."
                        TextColor="#BDBDBD" />

                    <Button
                        Text="Ver Solicitudes"
                        Clicked="OnRequestsClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="14"
                        Margin="0,10,0,0" />

                </VerticalStackLayout>

            </Frame>

            <!-- PERFIL -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="👤 Perfil"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Edita tu información."
                        TextColor="#BDBDBD" />

                    <Button
                        Text="Editar Perfil"
                        Clicked="OnProfileClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="14"
                        Margin="0,10,0,0" />

                </VerticalStackLayout>

            </Frame>

            <!-- CHAT -->

            <Frame
                BackgroundColor="#1E1E1E"
                BorderColor="#333333"
                CornerRadius="20"
                Padding="20">

                <VerticalStackLayout>

                    <Label
                        Text="💬 Chat"
                        FontSize="22"
                        FontAttributes="Bold"
                        TextColor="White" />

                    <Label
                        Text="Comunícate con clientes."
                        TextColor="#BDBDBD" />

                    <Button
                        Text="Abrir Chat"
                        Clicked="OnChatClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        CornerRadius="14"
                        Margin="0,10,0,0" />

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>